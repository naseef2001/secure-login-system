# Security Configuration
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-characters
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database Configuration
# SQLite (Development)
DATABASE_URL=sqlite:///secure_login.db

# MySQL (Production)
# DATABASE_URL=mysql+pymysql://username:password@localhost/secure_login_db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://username:password@localhost/secure_login_db

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
# FLASK_ENV=production

# reCAPTCHA (Optional - Get from Google reCAPTCHA)
RECAPTCHA_PUBLIC_KEY=your-recaptcha-public-key
RECAPTCHA_PRIVATE_KEY=your-recaptcha-private-key

# Email Configuration (For future features)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password